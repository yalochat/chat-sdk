# Android SDK location (set automatically by Android Studio)
sdk.dir=/path/to/Android/sdk

# ── Demo app credentials (consumed by app/build.gradle.kts) ───────────────────
# Copy this file to local.properties and fill in the values.
# local.properties is gitignored — credentials will never be committed.

yalo.channelName=your-channel-name
yalo.channelId=your-channel-id
yalo.organizationId=your-organization-id

# Set to true to use FakeYaloMessageRepository with seed data (no network calls).
# Set to false (or omit) to use the real backend. Defaults to false.
yalo.useFakeRepository=false
